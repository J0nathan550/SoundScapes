<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             BackgroundColor="#000000"
             x:Class="SoundScapes.Pages.SearchPage">
    <Grid Padding="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" StrokeShape="RoundRectangle 10,10,10,10" StrokeThickness="0">
            <SearchBar FontFamily="GothamMedium" IsTextPredictionEnabled="True" TextColor="White" Placeholder="Що ви хочете послухати?" PlaceholderColor="White" BackgroundColor="#212121"/>
        </Border>
        <ScrollView Margin="0,10,0,0" Grid.Row="1">
            <VerticalStackLayout Padding="5" Spacing="20">
                <Button/>
                <Button/>
                <Button/>
                <Button/>
                <Button/>
                <Button/>
                <Button/>
                <Button/>
                <Button/>
                <Button/>
                <Button/>
                <Button/>
                <Button/>
                <Button/>
                <Button/>
                <Button/>
                <Button/>
                <Button/>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>