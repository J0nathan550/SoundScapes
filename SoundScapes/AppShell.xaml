<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SoundScapes.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:SoundScapes.Pages"
    Shell.FlyoutBehavior="Flyout"
    FlyoutBackgroundColor="#1C1C1C"
    Title="SoundScapes">

    <TabBar>
        <Tab Title="Пошук" Icon="magnifying_glass_solid.svg">
            <ShellContent ContentTemplate="{DataTemplate local:SearchPage}" />
        </Tab>
        <Tab Title="Бібліотека" Icon="list_solid.svg">
            <ShellContent ContentTemplate="{DataTemplate local:LibraryPage}" />
        </Tab>
        <Tab Title="Налаштування" Icon="gear_solid.svg">
            <ShellContent ContentTemplate="{DataTemplate local:SettingsPage}" />
        </Tab>
    </TabBar>

    <ShellContent Title="Пошук" FlyoutIcon="magnifying_glass.png" ContentTemplate="{DataTemplate local:SearchPage}" />
    <ShellContent Title="Бібліотека" FlyoutIcon="list_solid_image.png" ContentTemplate="{DataTemplate local:LibraryPage}" />
    <ShellContent Title="Налаштування" FlyoutIcon="gear_image.png" ContentTemplate="{DataTemplate local:SettingsPage}" />

</Shell>