<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SoundScapes.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:SoundScapes.Pages"
    Shell.FlyoutBehavior="Disabled"
    Shell.TabBarIsVisible="True"
    FlyoutBackgroundColor="#1C1C1C"
    Title="Sound Scapes">

    <TabBar>
        <Tab Title="Пошук" Icon="magnifying_glass.png">
            <ShellContent ContentTemplate="{DataTemplate local:SearchPage}" />
        </Tab>
        <Tab Title="Бібліотека" Icon="list_solid_image.png">
            <ShellContent ContentTemplate="{DataTemplate local:LibraryPage}" />
        </Tab>
        <Tab Title="Налаштування" Icon="gear_image.png">
            <ShellContent ContentTemplate="{DataTemplate local:SettingsPage}" />
        </Tab>
    </TabBar>
</Shell>