<maui:MauiWinUIApplication
    x:Class="SoundScapes.WinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:maui="using:Microsoft.Maui"
    xmlns:local="using:SoundScapes.WinUI">
    <Application.Resources>

        <DataTemplate x:Key="MauiAppTitleBarTemplate">
            <!--<Border Style="{StaticResource TitleBarStyle}" VerticalAlignment="Stretch"/>-->
            <Grid Background="#1C1C1C" Canvas.ZIndex="1" Height="32" VerticalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Image Margin="2" Source="soundscapes_icon.png"/>
                <TextBlock Grid.Column="1" Text="Sound Scapes" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="5,0,0,2"/>
            </Grid>
        </DataTemplate>

    </Application.Resources>
</maui:MauiWinUIApplication>